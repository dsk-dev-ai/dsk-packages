{
  "name": "@darshankachare/logger",
  "version": "1.0.0",
  "private": false,
  "description": "A lightweight, type-safe logging library for Node.js and browser",
  "license": "MIT",
  "author": "Darshan Kachare",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dsk-dev-ai/dsk-packages.git",
    "directory": "packages/logger"
  },
  "homepage": "https://github.com/dsk-dev-ai/dsk-packages/tree/main/packages/logger#readme",
  "bugs": {
    "url": "https://github.com/dsk-dev-ai/dsk-packages/issues"
  },
  "keywords": [
    "logger",
    "typescript",
    "logging",
    "nodejs",
    "developer-tools",
    "structured-logging"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^6.0.3",
    "vitest": "^3.1.1"
  }
}
